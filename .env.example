# Yapi项目配置

# Server configuration
PORT=3388

# Token配置
# 多项目Token格式: projectId:token,projectId:token
YAPI_TOKEN=projectId:your_yapi_token_here,projectId2:your_yapi_token2_here

# 项目基础URL
YAPI_BASE_URL=your_yapi_base_url_here

# 缓存时效(分钟)，默认10分钟(6小时)
YAPI_CACHE_TTL=10

# 日志级别: debug, info, warn, error, none
# - debug: 输出所有日志，包括详细的调试信息
# - info: 输出信息、警告和错误日志(默认)
# - warn: 只输出警告和错误日志
# - error: 只输出错误日志
# - none: 不输出任何日志
YAPI_LOG_LEVEL=info

# 高级 Mock：先携带项目 token 请求；如果插件返回未登录，可自动读取浏览器 Cookie 后重试
YAPI_MOCK_USE_TOKEN=true
YAPI_MOCK_BROWSER_COOKIE=true
YAPI_MOCK_BROWSER_DEBUG_URL=http://127.0.0.1:9222

# 如果不使用浏览器自动读取，也可以手动配置固定 Cookie 或请求头
# YAPI_MOCK_COOKIE=_yapi_token=xxx; _yapi_uid=xxx
# YAPI_MOCK_AUTH_HEADER=Cookie: _yapi_token=xxx; _yapi_uid=xxx
